# =============================================================================
# BankOffer AI — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# This file is committed as a reference with default/demo values.
# For production, replace all secrets with strong random values.
# =============================================================================

# ---- Database (PostgreSQL 16) ----
# Server uses: 4e92aea555b546afcf85d66f8c247f78
DB_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/bankofferingai

# ---- Redis 7 ----
REDIS_URL=redis://redis:6379/0

# ---- Keycloak (SSO / Identity Provider) ----
# Local compose instance (Keycloak 25, proxied via nginx at /auth/)
KC_ADMIN_PASSWORD=Admin@KC2024!

# Standalone Keycloak server (Keycloak 26.2, accessed via Pangolin)
KC_STANDALONE_URL=https://auth.lupulup.com
KC_STANDALONE_ADMIN_USER=admin
KC_STANDALONE_ADMIN_PASSWORD=b5c7ea159931652e466d71e87299d40a970e2bd502f3ebcc

# Keycloak Realm & Client
KC_REALM=bankofferai
KC_CLIENT_ID=bankofferai-app
# bankofferai-app is a public client (no client_secret), uses PKCE S256

# ---- Application ----
DEMO_MODE=true
APP_URL=https://bankoffer.lupulup.com

# ---- Pangolin (Reverse Proxy / TLS) ----
PANGOLIN_API_URL=http://192.168.1.161:3003
PANGOLIN_API_TOKEN=shl9jlpicfirki5.cdx2hpcxgejt4cvjcl45tcdfjmtnnalmaya2lapn
PANGOLIN_ORG_ID=lupulup
PANGOLIN_SITE_ID=2

# ---- Infrastructure Hosts ----
APP_SERVER_IP=192.168.1.141
KEYCLOAK_SERVER_IP=192.168.1.190
PANGOLIN_SERVER_IP=192.168.1.161

# =============================================================================
